# Copie este archivo a .env y ajuste los valores

# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=viveros_db

# Autenticacion
# IMPORTANTE: cambie este valor en produccion por un secreto fuerte
JWT_SECRET=desarrollo-cambiar-en-produccion
JWT_EXPIRES_IN=1h

# CORS: lista separada por comas. Vacio para permitir cualquier origen.
FRONTEND_URL=

# Seed del primer administrador (consumido por "npm run seed")
SEED_ADMIN_CORREO=admin@viveros.local
SEED_ADMIN_NOMBRE=Administrador
SEED_ADMIN_PASSWORD=Admin123!
